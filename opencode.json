{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".agents/skills"]
  },
  "references": {
    "docs": {
      "path": "./docs",
      "description": "Use for application documentation"
    }
  },
  "experimental": {
    "primary_tools": ["edit"],
    "mcp_timeout": 30000
  },
  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  },
  "compaction": {
    "auto": true,
    "tail_turns": 15
  }
}
